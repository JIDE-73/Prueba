generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}
enum Role {
  Administrador
  Tutor
  Estudiante

  @@schema("auth")
}
model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  password  String
  image     String?
  tokenLogs tokenLog[]
  person    Person?

  @@schema("auth")
}

model Person {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  name         String
  phone        String?
  email        String    @unique
  work_hours   Json?
  institution  String?
  role         Role @default(Estudiante)

  tutorCourses Course[]  @relation("TutorToCourse")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses      Course[]  @relation("PersonToClass")
  sessions     Session[] @relation("SessionPersons")

  @@schema("public")
}

model Course {
  id           Int       @id @default(autoincrement())
  placeId      Int
  tutorId      Int
  name         String
  period       String
  
  place        Place     @relation(fields: [placeId], references: [id])
  tutor        Person    @relation("TutorToCourse", fields: [tutorId], references: [id])
  session      Session[]
  participants Person[]  @relation("PersonToClass")

  @@map("Class")
  @@schema("public")
}

model Place {
  id      Int      @id @default(autoincrement())
  name    String
  busy    Boolean  @default(false)
  courses Course[]

  @@schema("public")
}

model Session {
  id          Int      @id @default(autoincrement())
  classId     Int
  date_init   DateTime
  date_end    DateTime
  hours_day   Int
  total_hours Int
  status      String
  courses     Course   @relation(fields: [classId], references: [id])
  persons     Person[] @relation("SessionPersons")

  @@map("Session")
  @@schema("public")
}

model tokenLog {
  id         Int      @id @default(autoincrement())
  usuario_id Int
  token      String   @unique
  revocado   Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@index([token])
  @@schema("auth")
}
